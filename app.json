{
  "expo": {
    "name": "temp-app",
    "slug": "temp-app",
    "scheme": "capysmoney",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.capysmoney.app"
    },
    "android": {
      "package": "com.capysmoney.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "pwa": {
        "name": "Capy's Money",
        "shortName": "Capy Money",
        "description": "Quản lý tài chính cá nhân thảnh thơi cùng Capy",
        "backgroundBackgroundColor": "#fff8f7",
        "themeColor": "#864e5a",
        "display": "standalone",
        "orientation": "portrait",
        "startUrl": "/",
        "icon": "./assets/icon.png"
      }
    },
    "plugins": [
      "expo-web-browser"
    ]
  }
}
